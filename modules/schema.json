{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sshpub/dotfiles/modules/schema.json",
  "_comment": "JSON Schema for module.json — validates dotfiles module metadata",
  "title": "Dotfiles Module",
  "type": "object",
  "required": ["name", "version", "description"],
  "additionalProperties": false,
  "properties": {
    "_comment": {
      "type": "string",
      "description": "Documentation field (JSON has no comments)"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Module identifier (lowercase, hyphens allowed)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "description": {
      "type": "string",
      "description": "One-line description of the module"
    },
    "author": {
      "type": "string",
      "description": "Module author"
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["macos", "linux", "wsl"]
      },
      "uniqueItems": true,
      "description": "Supported platforms (omit for all)"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "uniqueItems": true,
      "description": "Modules that must load before this one"
    },
    "sections": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*$": {
          "type": "string",
          "description": "Section description"
        }
      },
      "additionalProperties": false,
      "description": "Map of {module}.{section} names to descriptions"
    },
    "shell": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "load_order": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "\\.sh$"
          },
          "description": "Ordered list of shell files to source"
        }
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "macos": { "$ref": "#/$defs/install_recipes" },
        "linux": { "$ref": "#/$defs/install_recipes" },
        "wsl": { "$ref": "#/$defs/install_recipes" }
      },
      "description": "Per-platform install recipes"
    },
    "symlinks": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Map of module paths to home directory symlink targets"
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "post_install": {
          "type": "string",
          "description": "Command to run after package installation"
        },
        "post_enable": {
          "type": "string",
          "description": "Command to run after module is enabled"
        }
      }
    }
  },
  "$defs": {
    "install_recipes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "brew": {
          "type": "array",
          "items": { "type": "string" }
        },
        "apt": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dnf": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pacman": {
          "type": "array",
          "items": { "type": "string" }
        },
        "snap": {
          "type": "array",
          "items": { "type": "string" }
        },
        "zypper": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inherit": {
          "type": "string",
          "enum": ["macos", "linux", "wsl"],
          "description": "Inherit recipes from another platform"
        }
      }
    }
  }
}
